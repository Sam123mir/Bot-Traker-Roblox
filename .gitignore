# X-Blaze — .gitignore
__pycache__/
*.pyc
*.pyo

# Logs (no subir al repo)
logs/

# Datos locales (se regeneran sólo en producción)
# Datos locales (hacer track para sync GitHub Render -> Main)
!data/**/*.json
!data/servers/**/*.json
!data/versions.json
!data/guilds.json
!data/announcements.json

# Archivos temporales
tmp_*.py
tmp_*.txt
out.txt

# Env
.env
*.env
python-dotenv
